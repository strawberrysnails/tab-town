{
  "manifest_version": 2,
  "name": "Tab Town",
  "version": "1.2",
  "description": "A custom new tab page, using catppucin palette, for personal use",
  "author": "strawberrysnails",
  "homepage_url": "https://strawberrysnails.github.io/",
 "browser_specific_settings": {
    "gecko": {
    "id": "tabtownbystrawberrysnails@firefox",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },
  "chrome_url_overrides": {
    "newtab": "index.html"
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "permissions": [
    "storage"
  ]
}